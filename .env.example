# ==================== 校园垃圾分类AI助手 - 环境变量配置模板 ====================
# 复制此文件为 .env 后修改对应值（.env 不会被 Git 跟踪）
#
# 使用方式：
#   1. cp .env.example .env
#   2. 编辑 .env 修改配置
#   3. 重启服务

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
RELOAD=true

# ==================== 数据库配置 ====================
DATABASE_PATH=data/app.db

# ==================== 模型配置 ====================
MODEL_PATH=models/garbage_yolov8m_best.pt
USE_YOLO_PT_MODEL=true
YOLO_INPUT_SIZE=640
CONFIDENCE_THRESHOLD=0.25

# ==================== 安全配置 ====================
SECRET_KEY=change-this-to-a-random-string-in-production
CORS_ORIGINS=*

# ==================== OAuth 配置（可选） ====================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ==================== 缓存配置 ====================
CACHE_MAX_ITEMS=500
CACHE_TTL_HOURS=24

# ==================== 历史记录配置 ====================
HISTORY_MAX_ITEMS=200
HISTORY_BACKUP_PATH=data/history.json
