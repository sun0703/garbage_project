# 校园垃圾分类AI助手 - 环境变量配置
# 复制为 .env 后修改，.env 不会被Git跟踪

# 服务器
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
RELOAD=false
LOG_FORMAT=json

# 数据库
# 开发环境用SQLite，生产环境用PostgreSQL（Docker Compose自动注入）
DATABASE_PATH=data/app.db
# DATABASE_URL=postgresql://ecosort:ecosort123@db:5432/ecosort

# PostgreSQL（Docker Compose用）
PG_USER=ecosort
PG_PASSWORD=ecosort123
PG_DB=ecosort
PG_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=ecosort2024
REDIS_PORT=6379

# 模型
MODEL_PATH=models/garbage_yolov8m_best.pt
USE_YOLO_PT_MODEL=true
YOLO_INPUT_SIZE=640
CONFIDENCE_THRESHOLD=0.25

# 安全
SECRET_KEY=change-this-to-a-random-string-in-production
CORS_ORIGINS=*

# OAuth（后面接入微信/GitHub登录时再填）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# 缓存
CACHE_MAX_ITEMS=500
CACHE_TTL_HOURS=24

# 历史记录
HISTORY_MAX_ITEMS=200
HISTORY_BACKUP_PATH=data/history.json

# 监控
ENABLE_METRICS=true
